{
  "name": "pathshopper2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite dev --port 5900",
    "build": "vite build",
    "tsc": "tsc --pretty --noEmit",
    "biome": "biome check --error-on-warnings",
    "format": "biome format --write .",
    "preview": "vite preview",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "process-data": "tsx scripts/process-items.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "checks": "pnpm format && pnpm tsc && pnpm biome && pnpm knip && pnpm test"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "knip": "^6.1.0",
    "marked": "^17.0.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}

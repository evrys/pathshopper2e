{
  "name": "guessygame",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5900",
    "build": "tsc -b && vite build",
    "tsc": "tsc --pretty --noEmit",
    "biome": "biome check --error-on-warnings",
    "format": "biome format --write .",
    "preview": "vite preview",
    "fetch-data": "tsx scripts/fetch-equipment.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "checks": "pnpm tsc && pnpm biome && pnpm test"
  },
  "dependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
